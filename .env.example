# Server Port
PORT=3006

# === Health & Wellness Integrations ===

# Whoop (OAuth2) - https://developer.whoop.com
# 1. Create app at developer.whoop.com
# 2. Complete OAuth flow to get refresh token
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=
WHOOP_REDIRECT_URI=http://localhost:3006/api/health/whoop/callback

# Eight Sleep - https://eightsleep.com
# Use your Eight Sleep app login credentials
EIGHT_SLEEP_EMAIL=
EIGHT_SLEEP_PASSWORD=
EIGHT_SLEEP_CLIENT_ID=
EIGHT_SLEEP_CLIENT_SECRET=

# Renpho - https://renpho.com
# Use your Renpho app login credentials
RENPHO_EMAIL=
RENPHO_PASSWORD=

# Apple Health (via Health Auto Export iOS app)
# Set a secret to validate incoming webhook requests
# Generate with: openssl rand -hex 32
APPLE_HEALTH_WEBHOOK_SECRET=

# === Home Dashboard Integrations ===

# OpenWeatherMap - https://openweathermap.org (free tier)
OPENWEATHER_API_KEY=

# World Tides Info - https://worldtides.info (free tier: 500 calls/month)
WORLDTIDES_API_KEY=

# Google Calendar (OAuth2) - https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
FAMILY_CALENDAR_ID=primary

# === Database (Supabase) ===
# Shared Supabase instance (Relativo CRM + CommandCentre)
# CRM tables (contacts, interactions, saved_views) live here
# Health data caching uses local SQLite regardless
SUPABASE_URL=https://hudacpdajmfsejnbognh.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
